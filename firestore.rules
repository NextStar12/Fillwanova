rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reusable core helper validation functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation schema helper block for Ticket documents
    function isValidTicket(data) {
      return data.id is string
        && data.title is string && data.title.size() <= 1000
        && data.description is string && data.description.size() <= 10000
        && data.category is string
        && data.priority is string
        && data.status is string
        && data.location is string
        && data.createdAt is string
        && data.updatedAt is string;
    }

    // Default-deny secure catch-all gate
    match /{document=**} {
      allow read, write: if false;
    }

    // Ticket rules match block
    match /tickets/{ticketId} {
      allow read, list: if true;
      allow create: if isValidTicket(request.resource.data) && isValidId(ticketId);
      allow update: if isValidTicket(request.resource.data) && isValidId(ticketId);
      allow delete: if true;
    }
  }
}
